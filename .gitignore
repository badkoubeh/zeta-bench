.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Editors / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Local secrets — never commit
.env

# Local AI/editor tool state
.claude/

# Working docs / personal notes (not part of the repo).
# Ignore contents (not the directory itself) so specific public docs can be
# re-included below — git does not descend into fully-ignored directories.
docs/*
!docs/usage.md
!docs/env_config_reference.md
!docs/reward_engineering.md

# Jupyter
.ipynb_checkpoints/
